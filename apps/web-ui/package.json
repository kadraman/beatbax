{
  "name": "@beatbax/web-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prepare-public": "node scripts/prepare-public-assets.js",
    "prepare-local": "node scripts/prepare-plugins.js && node ../../scripts/link-local-engine.cjs",
    "dev": "npm run prepare-local && npm run prepare-public && concurrently -k \"npm -w @beatbax/engine run dev\" \"vite\"",
    "dev:clean": "npm run prepare-local && npm run prepare-public && concurrently -k \"npm -w @beatbax/engine run dev\" \"vite --force\"",
    "build": "npm run prepare-local && npm run prepare-public && vite build && node scripts/verify-bundle.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "preview": "vite preview"
  },
  "dependencies": {
    "@beatbax/engine": "*",
    "@beatbax/plugin-chip-nes": "^0.6.1",
    "@beatbax/plugin-chip-sms": "^0.3.0",
    "@beatbax/plugin-chip-spectrum-128": "^0.2.0",
    "@beatbax/plugin-exporter-famitracker": "^0.2.2",
    "@beatbax/plugin-exporter-vgm": "^0.1.4",
    "@tailwindcss/vite": "^4.2.2",
    "buffer": "^6.0.3",
    "dompurify": "^3.3.3",
    "marked": "^5.1.2",
    "monaco-editor": "^0.45.0",
    "nanostores": "^1.2.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^29.5.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.0.0",
    "concurrently": "^9.1.2",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.9",
    "vite": "^5.0.0"
  }
}
