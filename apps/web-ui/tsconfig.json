{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "baseUrl": "..\\.."
    ,
    "paths": {
      "@beatbax/engine": ["packages/engine/dist/index.d.ts"],
      "@beatbax/engine/*": ["packages/engine/dist/*"],
      "@beatbax/app-core": ["packages/app-core/src/index.ts"],
      "@beatbax/app-core/*": ["packages/app-core/src/*"]
    }
  },
  "references": [
    { "path": "../../packages/engine" },
    { "path": "../../packages/app-core" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
