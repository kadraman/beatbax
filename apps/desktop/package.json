{
  "name": "@beatbax/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop client for BeatBax.",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf out dist test-results playwright-report",
    "prepare-local": "node ../../scripts/link-local-engine.cjs && npm -w @beatbax/app-core run build",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dev": "npm run prepare-local && node ../../node_modules/electron-vite/bin/electron-vite.js dev",
    "start": "node ../../node_modules/electron-vite/bin/electron-vite.js preview",
    "build": "npm run prepare-local && npm run typecheck && node ../../node_modules/electron-vite/bin/electron-vite.js build",
    "dist": "npm run build && node ../../node_modules/electron-builder/cli.js --publish never",
    "test": "npm run prepare-local && jest --config ./jest.config.cjs --runInBand",
    "test:e2e": "npm run build && playwright test --config ./playwright.config.ts",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@beatbax/app-core": "*",
    "@beatbax/engine": "*",
    "@beatbax/plugin-chip-sms": "^0.3.2",
    "@beatbax/plugin-chip-spectrum-128": "^0.2.1",
    "@beatbax/plugin-exporter-famitracker": "^0.2.3",
    "@beatbax/plugin-exporter-vgm": "^0.1.4",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "buffer": "^6.0.3",
    "monaco-editor": "^0.45.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.55.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.3.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
