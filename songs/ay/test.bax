chip zx-spectrum-128
bpm 128

# Multi-channel AY-3-8910 stability test for web-ui playback

# Channel 1: sustained melodic tone
inst lead  type=tone       vol=13

# Channel 2: bass body + occasional tone/noise attack
inst bass  type=tone       vol=11
inst pluck type=tone_noise vol=10 noise_rate=4

# Channel 3: noise percussion
inst kick  type=noise noise=on noise_rate=24 vol=14 note=C2
inst hat   type=noise noise=on noise_rate=2  vol=8  note=C5

pat lead_a = A4:8 . C5:8 . E5:8 . D5:8 .
pat lead_b = E5:8 . D5:8 . C5:8 . B4:8 .

pat bass_a = A2:16 . E2:16 .
pat bass_b = F2:16 . G2:16 .

pat drum_a = kick . hat . kick . hat .
pat drum_b = kick . hat . pluck . hat .

seq lead_seq = lead_a lead_b
seq bass_seq = bass_a bass_b
seq drum_seq = drum_a drum_b

channel 1 => inst lead seq lead_seq
channel 2 => inst bass seq bass_seq
channel 3 => inst kick seq drum_seq

play
