chip atari-st
bpm 132

inst lead type=tone env=attack_decay vol=use_envelope arp_env=[0,4,7|0]
inst bass type=tone env=decay_only vol=12

pat a = C5:4 F5:4 G5:4 A5:4
pat b = C3 . G2 . A2 . F2 .

seq lead_seq = a a
seq bass_seq = b b

channel 1 => inst lead seq lead_seq
channel 2 => inst lead seq lead_seq:oct(-1)
channel 3 => inst bass seq bass_seq

play
