chip msx
bpm 146

inst lead type=tone env=attack_decay vol=use_envelope pitch_env=[0,1,0,-1|0]
inst bass type=tone env=decay_only vol=11 pitch_env=[0,-12]
inst kick type=noise noise=on noise_rate=12 env=decay_quick vol=14 note=C2

pat top = C5 D5 E5 G5 A5 G5 E5 D5
pat low = C3 kick G2 kick A2 kick F2 kick

seq top_seq = top top
seq low_seq = low low

channel 1 => inst lead seq top_seq
channel 2 => inst lead seq top_seq:oct(-1)
channel 3 => inst bass seq low_seq

play
