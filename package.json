{
  "name": "beatbax",
  "version": "0.1.0",
  "private": true,
  "description": "Live-coding language for retro console chiptunes.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/plugins/chip-sms",
    "packages/plugins/chip-spectrum-128",
    "packages/plugins/export-famitracker",
    "packages/plugins/export-vgm",
    "apps/*"
  ],
  "scripts": {
    "clean-all": "node scripts/run-workspaces.cjs clean",
    "build-all": "npm run clean-all && npm run engine:build && node scripts/link-local-engine.cjs && node scripts/run-workspaces.cjs build --exclude @beatbax/engine && node scripts/add-js-extensions.cjs && node scripts/check-dist.cjs && node scripts/link-local-plugins.cjs",
    "engine:build": "npm -w @beatbax/engine run build",
    "engine:test": "npm -w @beatbax/engine test",
    "engine:dev": "npm -w @beatbax/engine run dev",
    "engine:clean": "npm -w @beatbax/engine run clean",
    "cli:build": "npm -w @beatbax/cli run build",
    "cli:test": "npm -w @beatbax/cli test",
    "cli:dev": "npm run engine:build && npm -w @beatbax/cli run dev",
    "cli:clean": "npm -w @beatbax/cli run clean",
    "cli:debug": "node --loader ts-node/esm packages/cli/src/cli-dev.ts",
    "chip-sms:build": "npm -w @beatbax/plugin-chip-sms run build",
    "chip-sms:test": "npm -w @beatbax/plugin-chip-sms test",
    "chip-spectrum:build": "npm -w @beatbax/plugin-chip-spectrum run build",
    "chip-spectrum:test": "npm -w @beatbax/plugin-chip-spectrum test",
    "famitracker-exporter:build": "npm -w @beatbax/plugin-exporter-famitracker run build",
    "famitracker-exporter:test": "npm -w @beatbax/plugin-exporter-famitracker test",
    "vgm-exporter:build": "npm -w @beatbax/plugin-exporter-vgm run build",
    "vgm-exporter:test": "npm -w @beatbax/plugin-exporter-vgm test",
    "web-ui:build": "npm -w @beatbax/web-ui run build",
    "web-ui:test": "npm -w @beatbax/web-ui test",
    "web-ui:dev": "npm -w @beatbax/web-ui run dev",
    "app-core:build": "npm -w @beatbax/app-core run build",
    "app-core:test": "npm -w @beatbax/app-core test",
    "rebuild": "npm run clean && npm run build",
    "prepublishOnly": "npm run build",
    "watch": "tsc --watch",
    "dev": "npm run engine:build && npm -w @beatbax/engine run dev",
    "cli": "node scripts/cli-wrapper.js",
    "cli:ensure": "npm run cli:build --if-present",
    "test": "npm run engine:test && node scripts/run-workspaces.cjs test --exclude @beatbax/engine --exclude @beatbax/web-ui",
    "bin": "node bin/beatbax",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "validate-ast": "node scripts/validate-ast.cjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build-all && changeset publish",
    "desktop:dev": "npm -w @beatbax/desktop run dev",
    "desktop:build": "npm -w @beatbax/desktop run build",
    "desktop:test": "npm -w @beatbax/desktop run test",
    "desktop:dist": "npm -w @beatbax/desktop run dist"
  },
  "bin": {
    "beatbax": "bin/beatbax"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "marked": "^5.1.1",
    "midiconvert": "^0.4.7",
    "tone": "^14.8.49",
    "vgm-parser": "^0.12.0-beta.0"
  },
  "files": [
    "packages/engine/dist",
    "packages/cli/dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.4",
    "ajv": "^8.17.1",
    "esbuild": "^0.18.17",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.3.3",
    "ts-node": "^10.9.1",
    "tsx": "^3.12.7",
    "typescript": "^5.6.3"
  },
  "optionalDependencies": {
    "play-sound": "^1.1.6",
    "speaker": "^0.5.5"
  }
}
